# Copy to .env and fill in. See specs/001-tenant-router-middleware/quickstart.md

# MongoDB connection string (Node runtime only — never imported into the edge).
MONGODB_URI="mongodb://localhost:27017/job-application-tracker?replicaSet=rs0"

# Signs & verifies better-auth session + session-cache cookies.
# REQUIRED for edge-side getCookieCache() verification in proxy.ts.
# Generate with:  openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Base domain for the tenant router.
#   dev:  lvh.me           (*.lvh.me publicly resolves to 127.0.0.1)
#   prod: your apex domain (requires *.domain wildcard DNS + wildcard TLS cert)
ROOT_DOMAIN="lvh.me"

# Auth client base URL — the apex (no subdomain).
NEXT_PUBLIC_BETTER_AUTH_URL="http://lvh.me:3000"
